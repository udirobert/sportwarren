{
  "build": {
    "env": {
      "DISABLE_SENTRY_BUILD": "true",
      "NODE_OPTIONS": "--max-old-space-size=8192"
    }
  },
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/scout-settle",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/auto-scout",
      "schedule": "0 */6 * * *"
    }
  ]
}
