##############################################################
# SportWarren — Production Environment Variables
# Copy this file to .env.local for development
# Set all variables in your hosting provider for production
##############################################################

# ── Core ───────────────────────────────────────────────────
NODE_ENV=production
NEXT_PUBLIC_APP_NAME=SportWarren
NEXT_PUBLIC_CLIENT_URL=https://sportwarren.xyz

# ── Monitoring (Sentry) ───────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ── Database (REQUIRED) ────────────────────────────────────
# The app will THROW on startup if this is missing in production.
# Use a managed Postgres provider: Neon, Supabase, Railway, etc.
# DATABASE_URL: Use the POOLED connection string (for the app)
# DATABASE_DIRECT_URL: Use the DIRECT connection string (for migrations)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/sportwarren?sslmode=require&pgbouncer=true
DATABASE_DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/sportwarren?sslmode=require
LEGACY_DB_BOOTSTRAP=false

# ── Algorand ────────────────────────────────────────────────
ALGORAND_NETWORK=testnet
NEXT_PUBLIC_ALGORAND_NODE_URL=https://testnet-api.algonode.cloud
NEXT_PUBLIC_ALGORAND_INDEXER_URL=https://testnet-idx.algonode.cloud
ALGORAND_MATCH_VERIFICATION_APP_ID=756630713
# Never expose the deployer mnemonic in NEXT_PUBLIC_ on mainnet
# This is testnet only
NEXT_PUBLIC_ALGORAND_TEST_MNEMONIC=

# ── Avalanche ───────────────────────────────────────────────
AVALANCHE_NETWORK=fuji
AVALANCHE_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
AVALANCHE_CHAIN_ID=43113

# ── Kite AI ─────────────────────────────────────────────────
KITE_API_URL=https://api.gokite.ai
KITE_API_KEY=
KITE_AGENT_WALLET=
NEXT_PUBLIC_KITE_ENABLED=true

# ── Yellow Payments ──────────────────────────────────────────
YELLOW_ENABLED=true
NEXT_PUBLIC_YELLOW_ENABLED=true
YELLOW_APP_ID=
YELLOW_API_KEY=
NEXT_PUBLIC_YELLOW_APP_ID=
YELLOW_CLEARNODE_URL=wss://clearnet.yellow.com/ws
NEXT_PUBLIC_YELLOW_CLEARNODE_URL=wss://clearnet.yellow.com/ws
YELLOW_ASSET_SYMBOL=USDC
NEXT_PUBLIC_YELLOW_ASSET_SYMBOL=USDC
NEXT_PUBLIC_YELLOW_PLATFORM_WALLET=
YELLOW_MATCH_FEE_AMOUNT=1
NEXT_PUBLIC_YELLOW_MATCH_FEE_AMOUNT=1
NEXT_PUBLIC_YELLOW_SCOPE=sportwarren
NEXT_PUBLIC_YELLOW_EIP712_DOMAIN_NAME=Yellow Network
NEXT_PUBLIC_YELLOW_ALLOWANCE_AMOUNT=1000000000

# ── Chainlink ───────────────────────────────────────────────
NEXT_PUBLIC_CHAINLINK_ENABLED=true
CHAINLINK_WEATHER_ORACLE=
CHAINLINK_LOCATION_ORACLE=

# ── WalletConnect ───────────────────────────────────────────
# Get your project ID from https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ── OpenAI (AI staff room responses) ────────────────────────
OPENAI_API_KEY=

# ── Socket (real-time, optional) ────────────────────────────
NEXT_PUBLIC_SOCKET_URL=https://sportwarren.xyz

##############################################################
# DEPLOYMENT CHECKLIST (verify before going live)
# [ ] DATABASE_URL is set and DB is migrated (npx prisma migrate deploy)
# [ ] NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID is set
# [ ] NEXT_PUBLIC_ALGORAND_NODE_URL / INDEXER_URL are correct
# [ ] KITE_API_KEY is set if using Kite AI features
# [ ] NEXT_PUBLIC_YELLOW_PLATFORM_WALLET is set for live Yellow match fee payouts
# [ ] OPENAI_API_KEY is set for staff room AI responses
# [ ] Run: npx prisma generate && npx prisma migrate deploy
# [ ] Test wallet connect on the live domain (not localhost)
# [ ] Verify /api/health returns 200
##############################################################
