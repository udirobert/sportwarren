// SportWarren Database Schema
// Core MVP: Match Verification → XP → Engagement

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// USER & AUTHENTICATION
// ============================================================================

model User {
  id            String  @id @default(cuid())
  email         String? @unique
  walletAddress String  @unique @map("wallet_address")
  chain         String // 'algorand', 'avalanche', or 'lens'

  // Profile
  name        String?
  ensName     String?  @map("ens_name") // Resolved ENS/Lens display name
  walletLabel String?  @map("wallet_label") // User-set nickname for their wallet
  avatar   String?
  position String? // Preferred position

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  playerProfile      PlayerProfile?
  squads             SquadMember[]
  platformIdentities PlatformIdentity[]
  telegramLinkCodes  TelegramLinkCode[]
  matchesSubmitted   Match[]              @relation("MatchSubmitter")
  verifications      MatchVerification[]
  aiMemory           AiMemory?
  squadContexts      SquadPlayerContext[]
  squadMedia         SquadMedia[]

  // Availability (Multi-squad support)
  availabilities     SquadAvailability[]
  matchRsvps         MatchRsvp[]
  twinSignalPreferences TwinSignalPreference[]

  @@map("users")
}

// ============================================================================
// PLAYER PROFILE (XP & ATTRIBUTES)
// ============================================================================

model PlayerProfile {
  id     String @id @default(cuid())
  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Level & XP
  level    Int @default(1)
  totalXP  Int @default(0) @map("total_xp")
  seasonXP Int @default(0) @map("season_xp")

  // Career Stats
  totalMatches Int @default(0) @map("total_matches")
  totalGoals   Int @default(0) @map("total_goals")
  totalAssists Int @default(0) @map("total_assists")

  // Weekly Schedule (0=Sunday, 1=Monday, etc.)
  matchDayPreference Int @default(0) @map("match_day_preference")

  // Physical Condition (0-100)
  sharpness Int @default(50) @map("sharpness")

  // Reputation
  reputationScore Int @default(100) @map("reputation_score")

  // GOAT Network ERC-8004 Agent identity
  // Set after onboarding when the platform registers an on-chain agent
  // for this player. Null means registration hasn't been attempted or
  // Goat Network is not configured.
  goatAgentId Int? @map("goat_agent_id")

  // Scout (Peer Rating)
  scoutXP   Int    @default(0) @map("scout_xp")
  scoutTier String @default("rookie") @map("scout_tier") // rookie, trusted, elite
  hypeTags  Json?  @map("hype_tags") // { "Clutch": 5, "Engine": 3 }

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  attributes        PlayerAttribute[]
  matchStats        PlayerMatchStats[]
  formHistory       FormEntry[]
  activities        PhysicalActivity[]
  ratingsGiven      PeerRating[]       @relation("RatingGiven")
  ratingsReceived   PeerRating[]       @relation("RatingReceived")
  motmVotesGiven    MotmVote[]         @relation("MotmVoteGiven")
  motmVotesReceived MotmVote[]         @relation("MotmVoteReceived")
  sessionsAttended  SessionAttendee[]
  twin              PlayerTwin?

  @@map("player_profiles")
}

model PhysicalActivity {
  id        String        @id @default(cuid())
  profileId String        @map("profile_id")
  profile   PlayerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  type      String // 'run', 'gym', 'hiit', 'field_training'
  duration  Int // minutes
  intensity String // 'low', 'medium', 'high'
  distance  Float? // km, if applicable
  calories  Int?

  // Provider info
  source     String  @default("manual") // 'manual', 'strava', 'apple_health'
  externalId String? @map("external_id")

  // Impact
  xpGained      Int @default(0) @map("xp_gained")
  sharpnessGain Int @default(0) @map("sharpness_gain")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("physical_activities")
}

model PlayerAttribute {
  id        String        @id @default(cuid())
  profileId String        @map("profile_id")
  profile   PlayerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  // Attribute type: pace, shooting, passing, dribbling, defending, physical
  attribute String
  rating    Int    @default(50) // 0-99 FIFA style
  xp        Int    @default(0)
  xpToNext  Int    @default(100) @map("xp_to_next")
  maxRating Int    @default(99) @map("max_rating")

  // History (last 5 match ratings for this attribute)
  history Int[]

  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([profileId, attribute])
  @@map("player_attributes")
}

model FormEntry {
  id        String        @id @default(cuid())
  profileId String        @map("profile_id")
  profile   PlayerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  matchId   String @map("match_id")
  rating    Float // Match rating 1-10
  formValue Int    @map("form_value") // Calculated -5 to +5

  createdAt DateTime @default(now()) @map("created_at")

  @@map("form_entries")
}

// ============================================================================
// SQUADS
// ============================================================================

model Squad {
  id        String  @id @default(cuid())
  name      String
  shortName String  @map("short_name")
  logo      String?

  // Squad details
  founded    DateTime @default(now())
  homeGround String?  @map("home_ground")

  // Placeholder squads auto-created from match logging (opponent not yet on platform)
  isPlaceholder Boolean @default(false) @map("is_placeholder")

  // Weekly Schedule (0=Sunday, 1=Monday, etc.)
  preferredMatchDay Int @default(0) @map("preferred_match_day")

  // Treasury (simplified for MVP)
  treasuryBalance Int @default(0) @map("treasury_balance")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Digital Twin & Seasonality
  digitalTwin3dEnabled Boolean @default(false) @map("digital_twin_3d_enabled")
  digitalTwin3dTier    String? @map("digital_twin_3d_tier") // premium, streak_reward, partner, internal

  // Relations
  members            SquadMember[]
  groups             SquadGroup[]
  squadContexts      SquadPlayerContext[]
  squadTwin          SquadTwin?
  matchesHome        Match[]              @relation("MatchHomeSquad")
  matchesAway        Match[]              @relation("MatchAwaySquad")
  tactics            SquadTactics?
  treasury           SquadTreasury?
  transferOffersFrom TransferOffer[]      @relation("TransferFromSquad")
  transferOffersTo   TransferOffer[]      @relation("TransferToSquad")
  challengesFrom     MatchChallenge[]     @relation("ChallengeFromSquad")
  challengesTo       MatchChallenge[]     @relation("ChallengeToSquad")
  sessions           Session[]

  // Availability & Scheduling (Multi-squad support)
  availabilities SquadAvailability[]
  schedule       SquadSchedule?

  // Media (private/squad/public)
  media   SquadMedia[]
  secrets SquadSecret[]

  // On-chain Governance
  governorAddress String? @map("governor_address")
  tokenAddress    String? @map("token_address")

  @@map("squads")
}

model SquadMember {
  id      String @id @default(cuid())
  squadId String @map("squad_id")
  squad   Squad  @relation(fields: [squadId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Role
  role     String   @default("player") // captain, vice_captain, player
  joinedAt DateTime @default(now()) @map("joined_at")

  // Temporal membership tracking for multi-squad support
  validFrom DateTime? @map("valid_from") // When membership started
  validTo   DateTime? @map("valid_to") // When membership ended (null = active)
  status    String    @default("active") // active, inactive, paused

  // Reverse relation for match submissions
  submittedMatches Match[] @relation("MatchSubmitterMembership")

  @@unique([squadId, userId])
  @@map("squad_members")
}

// ============================================================================
// SQUAD PLAYER CONTEXT (Per-Squad Stats & Role Progression)
// ============================================================================

model SquadPlayerContext {
  id     String @id @default(cuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  squadId String @map("squad_id")
  squad   Squad  @relation(fields: [squadId], references: [id], onDelete: Cascade)

  // Position in THIS squad (can differ from global preference)
  position String? // GK, DF, MF, ST, WG

  // Role in this squad
  role String @default("player") // captain, vice_captain, player

  // Per-squad XP (separate from global career XP)
  squadXP Int @default(0) @map("squad_xp")

  // Contextual stats (varies by squad)
  sharpness Int    @default(50) // 0-100, contextual fitness
  form      String @default("neutral") // hot, neutral, cold

  // Per-squad match stats
  matchesPlayed Int @default(0) @map("matches_played")
  goals         Int @default(0)
  assists       Int @default(0)

  // Timestamps
  joinedAt  DateTime @default(now()) @map("joined_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, squadId])
  @@map("squad_player_context")
}

model SquadGroup {
  id             String    @id @default(cuid())
  squadId        String    @map("squad_id")
  squad          Squad     @relation(fields: [squadId], references: [id], onDelete: Cascade)
  platform       String
  chatId         String?   @map("chat_id")
  platformUserId String?   @map("platform_user_id")
  username       String?
  linkToken      String?   @unique @map("link_token")
  linkedAt       DateTime? @map("linked_at")

  @@unique([platform, chatId])
  @@map("squad_groups")
}

// ============================================================================
// PLATFORM IDENTITY (User-Scoped Telegram/Discord Identity)
// ============================================================================

model PlatformIdentity {
  id     String @id @default(cuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  platform       String // telegram, discord
  platformUserId String  @map("platform_user_id") // Telegram user ID (stable)
  chatId         String? @map("chat_id") // Last group chat context
  username       String?
  firstName      String? @map("first_name") // Telegram first name
  photoUrl       String? @map("photo_url") // Telegram profile photo URL

  // Session fields (moved from PlatformConnection)
  miniAppToken          String?   @unique @map("mini_app_token")
  miniAppTokenExpiresAt DateTime? @map("mini_app_token_expires_at")
  activeSquadId         String?   @map("active_squad_id") // Last-used squad context

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([platform, platformUserId])
  @@map("platform_identities")
}

// Telegram link codes for self-service linking
model TelegramLinkCode {
  id     String @id @default(cuid())
  code   String @unique
  chatId String @map("chat_id") // Telegram chat ID
  userId String @map("user_id") // User to link to
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([chatId])
  @@index([userId])
  @@map("telegram_link_codes")
}

// ============================================================================
// SQUAD TACTICS
// ============================================================================

model SquadTactics {
  id      String @id @default(cuid())
  squadId String @unique @map("squad_id")
  squad   Squad  @relation(fields: [squadId], references: [id], onDelete: Cascade)

  // Formation (4-4-2, 4-3-3, etc.)
  formation String @default("4-4-2")

  // Play style
  playStyle String @default("balanced") @map("play_style")

  // Team instructions (JSON)
  instructions Json? // { width, tempo, passing, pressing, defensiveLine }

  // Set pieces (JSON)
  setPieces Json? @map("set_pieces") // { corners, freeKicks, penalties }

  // Starting lineup (array of player IDs aligned to formation slots)
  lineup Json? @map("lineup")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("squad_tactics")
}

model TacticalPlanShare {
  id          String   @id @default(cuid())
  slug        String   @unique
  fingerprint String   @unique

  formation String
  playStyle String @map("play_style")
  squadSize Int    @map("squad_size")
  color     String?

  names Json @default("[]")
  plan  Json

  source          String  @default("playground")
  createdByUserId String? @map("created_by_user_id")

  viewCount    Int       @default(0) @map("view_count")
  copyCount    Int       @default(0) @map("copy_count")
  lastViewedAt DateTime? @map("last_viewed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  claims ShareClaim[]

  @@index([createdAt])
  @@index([formation, playStyle, squadSize])
  @@map("tactical_plan_shares")
}

model ShareClaim {
  id             String   @id @default(cuid())
  shareId        String   @map("share_id")
  share          TacticalPlanShare @relation(fields: [shareId], references: [id], onDelete: Cascade)

  positionIndex  Int      @map("position_index")
  displayName    String   @map("display_name")

  // Optional: remix slug so the claimant can share a personalised link
  remixSlug      String?  @unique @map("remix_slug")

  // Optional: authenticated user id if they later sign up
  userId         String?  @map("user_id")

  claimedAt      DateTime @default(now()) @map("claimed_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // One claim per position per share
  @@unique([shareId, positionIndex], name: "share_position_unique")
  @@index([shareId])
  @@map("share_claims")
}

// DAO GOVERNANCE (PROPOSALS & VOTING) - Moved to Avalanche Smart Contracts

// ============================================================================
// TREASURY & TRANSACTIONS
// ============================================================================

model SquadTreasury {
  id      String @id @default(cuid())
  squadId String @unique @map("squad_id")
  squad   Squad  @relation(fields: [squadId], references: [id], onDelete: Cascade)

  // Balance in smallest unit (e.g., microALGO)
  balance          Int     @default(0)
  yellowSessionId  String? @map("yellow_session_id")
  tonWalletAddress String? @map("ton_wallet_address")

  // Budgets (JSON)
  budgets Json? // { wages, transfers, facilities }

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  transactions TreasuryTransaction[]

  @@map("squad_treasury")
}

model TreasuryTransaction {
  id         String        @id @default(cuid())
  treasuryId String        @map("treasury_id")
  treasury   SquadTreasury @relation(fields: [treasuryId], references: [id], onDelete: Cascade)

  // Transaction type
  type String // income, expense

  // Category
  category String // transfer_in, transfer_out, match_fee, tournament_prize, facility, wage

  // Amount
  amount Int

  // Description
  description String?

  // Verification (blockchain tx hash)
  txHash   String? @map("tx_hash")
  verified Boolean @default(false)
  metadata Json?

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")

  @@map("treasury_transactions")
}

// ============================================================================
// SOCIAL: SQUAD MEDIA (PRIVATE SHARING)
// ============================================================================

model SquadMedia {
  id String @id @default(cuid())

  squadId String @map("squad_id")
  squad   Squad  @relation(fields: [squadId], references: [id], onDelete: Cascade)

  uploaderId String @map("uploader_id")
  uploader   User   @relation(fields: [uploaderId], references: [id], onDelete: Cascade)

  // Title/caption
  title String?

  // Media details
  kind       String @default("image") // image, video
  mimeType   String @map("mime_type")
  size       Int // bytes
  storageKey String @map("storage_key") // opaque key/path, not public URL

  // Optional thumbnail
  thumbStorageKey String? @map("thumb_storage_key")
  thumbMimeType   String? @map("thumb_mime_type")
  thumbSize       Int?    @map("thumb_size")

  // Visibility: private (uploader only), squad (default), public
  visibility String @default("squad")

  createdAt DateTime @default(now()) @map("created_at")

  // Soft delete
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by")

  @@index([squadId])
  @@index([uploaderId])
  @@map("squad_media")
}

// ============================================================================
// SECURITY: SQUAD SECRETS (e.g., media encryption keys)
// ============================================================================

model SquadSecret {
  id String @id @default(cuid())

  squadId String @map("squad_id")
  squad   Squad  @relation(fields: [squadId], references: [id], onDelete: Cascade)

  kind   String // 'media_enc'
  keyEnc String @map("key_enc") // base64 of encrypted key material

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([squadId, kind])
  @@map("squad_secrets")
}

// ============================================================================
// TRANSFER MARKET
// ============================================================================

model TransferOffer {
  id String @id @default(cuid())

  // From/To squads
  fromSquadId String @map("from_squad_id")
  fromSquad   Squad  @relation("TransferFromSquad", fields: [fromSquadId], references: [id])
  toSquadId   String @map("to_squad_id")
  toSquad     Squad  @relation("TransferToSquad", fields: [toSquadId], references: [id])

  // Player (user ID)
  playerId String @map("player_id")

  // Offer details
  offerType    String @map("offer_type") // permanent, loan
  amount       Int
  loanDuration Int?   @map("loan_duration") // months, if loan

  // Status
  status          String  @default("pending") // pending, accepted, rejected, cancelled
  yellowSessionId String? @map("yellow_session_id")

  // Timestamps
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@map("transfer_offers")
}

// ============================================================================
// CHALLENGES & TERRITORY
// ============================================================================

model MatchChallenge {
  id String @id @default(cuid())

  fromSquadId String @map("from_squad_id")
  fromSquad   Squad  @relation("ChallengeFromSquad", fields: [fromSquadId], references: [id])
  toSquadId   String @map("to_squad_id")
  toSquad     Squad  @relation("ChallengeToSquad", fields: [toSquadId], references: [id])

  status String @default("pending") // pending, accepted, rejected, cancelled

  // Proposed details
  proposedDate DateTime @map("proposed_date")
  pitchId      String?  @map("pitch_id")
  pitch        Pitch?   @relation(fields: [pitchId], references: [id])
  message      String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("match_challenges")
}

model Pitch {
  id        String @id @default(cuid())
  name      String
  location  String
  latitude  Float
  longitude Float

  // Territory Control
  controllingSquadId String? @map("controlling_squad_id")

  // History
  challenges MatchChallenge[]
  matches    Match[]

  // Squad scheduling
  squadSchedules SquadSchedule[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("pitches")
}

// ============================================================================
// MATCHES (Core of MVP)
// ============================================================================

model Match {
  id String @id @default(cuid())

  // Teams
  homeSquadId String @map("home_squad_id")
  homeSquad   Squad  @relation("MatchHomeSquad", fields: [homeSquadId], references: [id])
  awaySquadId String @map("away_squad_id")
  awaySquad   Squad  @relation("MatchAwaySquad", fields: [awaySquadId], references: [id])

  // Match Format (flexible: 5-a-side to 15-a-side, optional keeper)
  playersPerSide Int     @default(11) @map("players_per_side")
  hasKeeper      Boolean @default(true) @map("has_keeper")
  matchFormat    String  @default("11v11") @map("match_format") // e.g. "5v5", "7v7", "11v11"

  // Score
  homeScore Int? @map("home_score")
  awayScore Int? @map("away_score")

  // Submitter
  submittedBy String @map("submitted_by")
  submitter   User   @relation("MatchSubmitter", fields: [submittedBy], references: [id])

  // Membership context - which squad membership was active when submitted
  // Enables historical attribution for multi-squad players
  submittedByMembershipId String?      @map("submitted_by_membership_id")
  submittedByMembership   SquadMember? @relation("MatchSubmitterMembership", fields: [submittedByMembershipId], references: [id])

  // Status
  status String @default("pending") // pending, verified, disputed, finalized

  // Public sharing
  shareSlug String? @unique @map("share_slug") // Short slug for public match URLs

  // Timestamps
  matchDate DateTime @map("match_date")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Oracle Verification (Chainlink)
  latitude            Float?
  longitude           Float?
  weatherVerified     Boolean @default(false) @map("weather_verified")
  locationVerified    Boolean @default(false) @map("location_verified")
  verificationDetails Json?   @map("verification_details")
  agentInsights       Json?   @map("agent_insights") // AI-generated captain reports

  // Pitch Relation
  pitchId String? @map("pitch_id")
  pitch   Pitch?  @relation(fields: [pitchId], references: [id])

  // Session Relation (for ad-hoc "Bibs vs Non-Bibs" games)
  sessionId String?  @map("session_id")
  session   Session? @relation(fields: [sessionId], references: [id])

  // Blockchain
  txId               String?   @map("tx_id") // Algorand transaction ID
  yellowFeeSessionId String?   @map("yellow_fee_session_id")
  yellowFeeSettledAt DateTime? @map("yellow_fee_settled_at")

  // Peer Rating Window
  peerRatingsClosed  Boolean   @default(false) @map("peer_ratings_closed")
  peerRatingsCloseAt DateTime? @map("peer_ratings_close_at")

  // Formation per side (captured at submission time from SquadTactics)
  homeFormation String? @map("home_formation") // e.g. "4-4-2", "4-3-3"
  awayFormation String? @map("away_formation") // e.g. "4-4-2", "4-3-3"

  // Relations
  verifications MatchVerification[]
  playerStats   PlayerMatchStats[]
  xpGains       XPGain[]
  peerRatings   PeerRating[]
  motmVotes     MotmVote[]
  rsvps         MatchRsvp[]

  @@map("matches")
}

// ============================================================================
// PEER RATINGS & MOTM
// ============================================================================

model PeerRating {
  id String @id @default(cuid())

  matchId String @map("match_id")
  match   Match  @relation(fields: [matchId], references: [id])

  raterId String        @map("rater_id")
  rater   PlayerProfile @relation("RatingGiven", fields: [raterId], references: [id])

  targetId String        @map("target_id")
  target   PlayerProfile @relation("RatingReceived", fields: [targetId], references: [id])

  attribute String // "pace", "shooting", "passing", "dribbling", "defending", "physical"
  score     Int // 1-10
  hypeTags  Json?   @map("hype_tags") // ["Clutch", "Engine"]
  weighted  Boolean @default(false)

  // Consensus result (populated after window closes)
  deviation Int? // How far this rating was from the median
  scoutXP   Int? @map("scout_xp") // XP earned/lost for this rating

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([matchId, raterId, targetId, attribute])
  @@map("peer_ratings")
}

model MotmVote {
  id String @id @default(cuid())

  matchId String @map("match_id")
  match   Match  @relation(fields: [matchId], references: [id])

  voterId String        @map("voter_id")
  voter   PlayerProfile @relation("MotmVoteGiven", fields: [voterId], references: [id])

  targetId String        @map("target_id")
  target   PlayerProfile @relation("MotmVoteReceived", fields: [targetId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([matchId, voterId])
  @@map("motm_votes")
}

model MatchVerification {
  id      String @id @default(cuid())
  matchId String @map("match_id")
  match   Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)

  verifierId String @map("verifier_id")
  verifier   User   @relation(fields: [verifierId], references: [id])

  // Verification details
  verified  Boolean
  homeScore Int?    @map("home_score")
  awayScore Int?    @map("away_score")

  // Trust
  trustTier String @map("trust_tier") // bronze, silver, gold, platinum

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([matchId, verifierId])
  @@map("match_verifications")
}

// ============================================================================
// PLAYER MATCH STATS (For XP Calculation)
// ============================================================================

model PlayerMatchStats {
  id String @id @default(cuid())

  matchId String @map("match_id")
  match   Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)

  profileId String        @map("profile_id")
  profile   PlayerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  // Stats
  goals         Int     @default(0)
  assists       Int     @default(0)
  cleanSheet    Boolean @default(false) @map("clean_sheet")
  rating        Float? // 1-10 match rating
  minutesPlayed Int     @default(90) @map("minutes_played")
  hypeTags      Json?   @map("hype_tags") // Aggregated consensus tags for the match

  // Calculated XP
  xpEarned Int @default(0) @map("xp_earned")

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([matchId, profileId])
  @@map("player_match_stats")
}

// ============================================================================
// XP GAINS (Audit Trail)
// ============================================================================

model XPGain {
  id String @id @default(cuid())

  matchId String? @map("match_id")
  match   Match?  @relation(fields: [matchId], references: [id])

  profileId String @map("profile_id")

  // XP breakdown
  baseXP  Int @map("base_xp")
  bonusXP Int @default(0) @map("bonus_xp")
  totalXP Int @map("total_xp")

  // Source
  source      String // match, training, achievement, etc.
  description String?

  // Attribute distribution (JSON)
  attributeBreakdown Json? @map("attribute_breakdown")
  // Example: {"shooting": 50, "passing": 30, "physical": 20}

  createdAt DateTime @default(now()) @map("created_at")

  @@map("xp_gains")
}

// ============================================================================
// ACHIEVEMENTS (Simplified for MVP)
// ============================================================================

model Achievement {
  id String @id @default(cuid())

  // Achievement type
  type        String @unique // hat_trick, clean_sheet, etc.
  title       String
  description String

  // Requirements
  requirement Json // Flexible requirements

  // Reward
  xpReward Int @default(0) @map("xp_reward")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  unlockedBy PlayerAchievement[]

  @@map("achievements")
}

model PlayerAchievement {
  id String @id @default(cuid())

  profileId     String      @map("profile_id")
  achievementId String      @map("achievement_id")
  achievement   Achievement @relation(fields: [achievementId], references: [id])

  unlockedAt DateTime @default(now()) @map("unlocked_at")

  @@unique([profileId, achievementId])
  @@map("player_achievements")
}

// ============================================================================
// SESSIONS (Ad-hoc "Weekly Games")
// ============================================================================

model Session {
  id      String @id @default(cuid())
  squadId String @map("squad_id")
  squad   Squad  @relation(fields: [squadId], references: [id], onDelete: Cascade)

  name String // e.g. "Wednesday Night Football"
  date DateTime @default(now())

  // Attendance (pool of players available for this session)
  attendees SessionAttendee[]

  // Matches generated from this session (Bibs vs No Bibs)
  matches Match[]

  // Status: open (collecting players), balanced (teams picked), completed
  status String @default("open")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("sessions")
}

model SessionAttendee {
  id        String  @id @default(cuid())
  sessionId String  @map("session_id")
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  profileId String        @map("profile_id")
  profile   PlayerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  // Preferred color/team for this session
  teamPreference String? @map("team_preference") // "bibs", "no_bibs"

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([sessionId, profileId])
  @@map("session_attendees")
}

// ============================================================================
// AI AGENTS (KITE AI)
// ============================================================================

model AiAgent {
  id           String   @id @default(cuid())
  agentId      String   @unique @map("agent_id")
  passportId   String   @unique @map("passport_id")
  name         String
  type         String // squad_manager, scout, fitness, social, twin_player, twin_squad, coach_external
  description  String
  reputation   Int      @default(100)
  capabilities String[]

  // Kite Passport ownership / scope
  ownerType     String? @map("owner_type") // 'player' | 'squad' | 'platform' | 'external'
  ownerId       String? @map("owner_id")
  walletAddress String? @map("wallet_address") // Kite chain address controlled by this agent

  // Service-provider mode (this agent sells an x402 service to other agents)
  serviceUrl    String? @map("service_url")
  servicePrice  String? @map("service_price") // e.g. "0.10"
  serviceAsset  String? @default("USDC") @map("service_asset")
  serviceActive Boolean @default(false) @map("service_active")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  sessions      KiteSession[]
  attestations  Attestation[]    @relation("AttestationSigner")
  coachingGiven CoachingEffect[] @relation("CoachingEffectCoach")
  playerTwin    PlayerTwin?

  @@index([ownerType, ownerId])
  @@map("ai_agents")
}

// ============================================================================
// KITE PASSPORT SPENDING SESSIONS
// Mirrors `kpass agent:session` — every paid call by an agent runs inside a
// session bounded by per-tx + total budget + ttl + scope. Persisted for audit.
// ============================================================================

model KiteSession {
  id      String  @id @default(cuid())
  agentId String  @map("agent_id")
  agent   AiAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  taskSummary     String @map("task_summary")
  scope           Json? // free-form scope hints (service categories, allowlisted urls)
  asset           String @default("USDC")
  paymentApproach String @default("x402_http") @map("payment_approach")

  maxPerTx Float @map("max_per_tx")
  maxTotal Float @map("max_total")
  spent    Float @default(0)
  txCount  Int   @default(0) @map("tx_count")

  status     String  @default("pending") // pending | active | expired | exhausted | revoked
  approvedBy String? @map("approved_by") // user id (passkey approval)
  requestId  String? @unique @map("request_id") // kpass session request id when human-approved

  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  attestations Attestation[]

  @@index([agentId, status])
  @@map("kite_sessions")
}

// ============================================================================
// ATTESTATIONS
// Every twin stat change requires a signed attestation. Records the on-chain
// settlement tx hash on Kite when the originating action was a paid x402 call.
// ============================================================================

model Attestation {
  id String @id @default(cuid())

  subjectType String @map("subject_type") // 'player' | 'squad' | 'match' | 'agent'
  subjectId   String @map("subject_id")

  kind    String // 'match_result' | 'peer_rating' | 'activity_sync' | 'coaching_effect' | 'motm' | 'rsvp_compliance'
  payload Json // canonicalized data that was signed

  signerAgentId String?  @map("signer_agent_id")
  signerAgent   AiAgent? @relation("AttestationSigner", fields: [signerAgentId], references: [id])
  signature     String? // hex EIP-712 / personal_sign

  // Kite-chain settlement
  network     String  @default("kite-testnet")
  txHash      String? @map("tx_hash")
  facilitator String? // pieverse address used
  amountUsdc  Float?  @map("amount_usdc") // amount paid for this attestation, if any

  // Deferred settlement tracking
  settlementStatus   String?    @map("settlement_status") // 'pending' | 'settled' | 'failed'
  settlementAttempts Int        @default(0) @map("settlement_attempts")
  settlementError    String?    @map("settlement_error")
  settledAt          DateTime?  @map("settled_at")

  // Optional link back to the spending session that paid for this attestation
  sessionId String?      @map("session_id")
  session   KiteSession? @relation(fields: [sessionId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@index([subjectType, subjectId, kind])
  @@index([txHash])
  @@map("attestations")
}

// ============================================================================
// COACHING EFFECTS
// Time-decaying buffs purchased via x402 from a coach agent. Stat = base +
// sum(active CoachingEffect modifiers). Every effect points back to the
// attestation that paid for + signed it.
// ============================================================================

model CoachingEffect {
  id String @id @default(cuid())

  // who is being coached
  targetType String @map("target_type") // 'player' | 'squad'
  targetId   String @map("target_id")

  // who provided the coaching
  coachAgentId String  @map("coach_agent_id")
  coachAgent   AiAgent @relation("CoachingEffectCoach", fields: [coachAgentId], references: [id])

  // what the buff is
  attribute String // e.g. 'shooting' | 'attack' | 'sharpness' | 'teamwork'
  modifier  Float // additive, can be negative (e.g. fatigue from over-training)
  reason    String?

  // proof
  attestationId String? @map("attestation_id")
  amountUsdc    Float?  @map("amount_usdc")

  // lifetime
  startsAt  DateTime @default(now()) @map("starts_at")
  expiresAt DateTime @map("expires_at")
  active    Boolean  @default(true)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([targetType, targetId, active, expiresAt])
  @@map("coaching_effects")
}

// ============================================================================
// WHATSAPP NOTIFICATIONS — 3/twin/day cap for milestone-tier delivery
// Each row is one outbound milestone message. Counted via 24h rolling window
// in `notify.ts`. Persisted so we can audit and tune caps later.
// ============================================================================

model WhatsAppNotification {
  id        String   @id @default(cuid())
  twinId    String   @map("twin_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([twinId, createdAt])
  @@map("whats_app_notifications")
}

// ============================================================================
// TWIN SIGNAL PREFERENCES — per-kind opt-in for notification channels
// ============================================================================

model TwinSignalPreference {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  channel   String   // 'telegram'
  kind      String   // MilestoneKind value: 'level_up', 'sim_win', etc.
  enabled   Boolean  @default(true)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, channel, kind])
  @@index([userId, channel])
  @@map("twin_signal_preferences")
}

// ============================================================================
// MOMENTS — declarative records of personalisation events with optional
// rendered image. Single row per event; render is lazy + idempotent.
// ============================================================================

model Moment {
  id String @id @default(cuid())

  subjectType String @map("subject_type") // 'player' | 'squad'
  subjectId   String @map("subject_id")

  kind   String // 'twin_created' | 'level_up' | 'sim_complete' | 'achievement' | 'coaching_hired' | 'coaching_expired' | 'attestation_milestone' | 'season_end' | 'record_broken'
  tier   String // 'standard' | 'premium' | 'streak_reward' | 'partner' | 'internal'
  label  String
  detail String?

  sourceEventId String?   @map("source_event_id") // attestation id
  renderedKey   String?   @map("rendered_key") // storage key of rendered PNG
  renderedAt    DateTime? @map("rendered_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([subjectType, subjectId, createdAt])
  @@map("moments")
}

model AiMemory {
  id     String @id @default(cuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Stored JSON representation of NarrativeEntry[]
  history Json @default("[]")

  // Array of strings or JSON for key insights
  keyInsights Json @default("[]") @map("key_insights")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId])
  @@map("ai_memories")
}


// ============================================================================
// AVAILABILITY & SCHEDULING (Multi-Squad Support)
// ============================================================================

// Recurring weekly availability - "I play every Tuesday"
model SquadAvailability {
  id     String @id @default(cuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  squadId String @map("squad_id")
  squad   Squad  @relation(fields: [squadId], references: [id], onDelete: Cascade)

  // Day of week (ISO: 1=Monday, 7=Sunday)
  dayOfWeek Int @map("day_of_week") // 1-7

  // Time preference
  timeSlot String? // "morning", "afternoon", "evening", "any"

  // Availability status
  isAvailable Boolean @default(true) @map("is_available")

  // Notes (e.g., "only if home game", "after 6pm")
  notes String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, squadId, dayOfWeek])
  @@map("squad_availabilities")
}

// One-off match RSVP - "I'm playing this Saturday"
model MatchRsvp {
  id     String @id @default(cuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  matchId String @map("match_id")
  match   Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)

  // Response status
  status String @default("pending") // "available", "unavailable", "maybe"

  // Payment tracking for informal games (subs/pitch fees)
  isPaid      Boolean   @default(false) @map("is_paid")
  paidAt      DateTime? @map("paid_at")
  amountPaid  Int?      @map("amount_paid") // in minor units (e.g. pence, or nanoTON)
  paymentType String?   @map("payment_type") // 'cash', 'transfer', 'crypto'

  // Position preference for this match
  position String? // GK, DF, MF, ST, WG, any

  // Notes (e.g., "might be late", "bringing a friend")
  notes String?

  respondedAt DateTime? @map("responded_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@unique([userId, matchId])
  @@map("match_rsvps")
}

// Squad's default schedule - "We play every Saturday 2pm at XYZ"
model SquadSchedule {
  id      String @id @default(cuid())
  squadId String @unique @map("squad_id")
  squad   Squad  @relation(fields: [squadId], references: [id], onDelete: Cascade)

  // Day of week (ISO: 1=Monday, 7=Sunday)
  dayOfWeek Int @map("day_of_week") // 1-7

  // Default time
  time String? // "14:00", "2pm"

  // Default location
  locationId String? @map("location_id")
  location   Pitch?  @relation(fields: [locationId], references: [id])

  // Recurrence
  isRecurring Boolean @default(true) @map("is_recurring")

  // Active/inactive
  isActive Boolean @default(true) @map("is_active")

  // Notes
  notes String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("squad_schedules")
}

// ============================================================================
// PLAYER TWINS — Kite Passport-backed autonomous agents per player
// Every player gets a twin whose stats are a verifiable function of IRL
// attestations (match results, peer ratings, activity sync). Twins can hire
// coaches (paid via x402), compete in simulated tournaments, and trade
// scouting data with other twins.
// ============================================================================

model PlayerTwin {
  id        String        @id @default(cuid())
  profileId String        @unique @map("profile_id")
  profile   PlayerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  // Kite Passport identity
  agentId String  @unique @map("agent_id") // AiAgent.id
  agent   AiAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  // Twin state
  level    Int @default(1)
  xp       Int @default(0)
  prestige Int @default(0) // earned through wins, coaching, attestations

  // Autonomous config (what the twin is allowed to do within its session budget)
  autoHireCoaches  Boolean @default(false) @map("auto_hire_coaches")
  autoCompete      Boolean @default(false) @map("auto_compete")
  weeklyBudgetUsdc Float   @default(5.0) @map("weekly_budget_usdc")

  // Stats snapshot (denormalized from attestations for fast reads)
  baseAttributes    Json      @default("{}") @map("base_attributes") // { pace: 50, shooting: 50, ... }
  activeModifiers   Json      @default("[]") @map("active_modifiers") // CoachingEffect[] with expiry
  lastAttestationAt DateTime? @map("last_attestation_at")

  // TwinService-driven metrics (added 2026-06-04, see migration
  // 20260604_unify_twin_schema). Reputation 0-1000, attestationCount is the
  // total twin has ever received (drives milestone detection).
  reputation       Int @default(0)
  attestationCount Int @default(0) @map("attestation_count")

  // Daily drill cooldown (PR 11)
  lastDailyDrillAt DateTime? @map("last_daily_drill_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  simulations TwinSimulationParticipant[]

  @@map("player_twins")
}

// ============================================================================
// SQUAD TWINS — squad-level brain (skin + twin, unified with PlayerTwin)
// Distinct row from player_twins: a squad has no PlayerProfile, so a squad
// twin is its own state container. The appliers in
// `src/server/services/personalization/twin-appliers.ts` are scope-agnostic
// and consume either shape via the unified `TwinState` type.
// ============================================================================

model SquadTwin {
  id      String @id @default(cuid())
  squadId String @unique @map("squad_id")
  squad   Squad  @relation(fields: [squadId], references: [id], onDelete: Cascade)

  level    Int @default(1)
  xp       Int @default(0)
  prestige Int @default(0)

  baseAttributes   Json    @default("{}") @map("base_attributes") // { pace: 50, shooting: 50, ... }
  energy           Int     @default(100) // 0-100, drains with ghost matches
  energyMax        Int     @default(100) @map("energy_max")
  consensusTags    Json?   @map("consensus_tags") // { "Clutch": 5, "Engine": 3 }
  twinActive       Boolean @default(true) @map("twin_active")
  // PR 2 — squad twin milestones (mirrors player_twins)
  reputation       Int     @default(0)
  attestationCount Int     @default(0) @map("attestation_count")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("squad_twins")
}

// ============================================================================
// TWIN SIMULATIONS — overnight tournaments between player twins
// ============================================================================

model TwinSimulation {
  id     String @id @default(cuid())
  name   String // "Week 14 Round-Robin"
  format String @default("round_robin") // round_robin | knockout | league
  status String @default("pending") // pending | running | completed | settled

  // Prize pool funded by entry fees (x402 settled)
  entryFeeUsdc    Float   @default(0)
  totalPrizeUsdc  Float   @default(0)
  prizePoolTxHash String? @map("prize_pool_tx_hash")

  // Kite-chain settlement
  network       String  @default("kite-testnet")
  attestationId String? @map("attestation_id") // master attestation for the whole simulation

  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now()) @map("created_at")

  participants TwinSimulationParticipant[]
  matches      TwinSimulationMatch[]

  @@map("twin_simulations")
}

model TwinSimulationParticipant {
  id           String         @id @default(cuid())
  simulationId String         @map("simulation_id")
  simulation   TwinSimulation @relation(fields: [simulationId], references: [id], onDelete: Cascade)
  twinId       String         @map("twin_id")
  twin         PlayerTwin     @relation(fields: [twinId], references: [id], onDelete: Cascade)

  // Tournament standing
  wins         Int   @default(0)
  draws        Int   @default(0)
  losses       Int   @default(0)
  goalsFor     Int   @default(0) @map("goals_for")
  goalsAgainst Int   @default(0) @map("goals_against")
  points       Int   @default(0)
  prizeUsdc    Float @default(0) @map("prize_usdc")

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([simulationId, twinId])
  @@map("twin_simulation_participants")
}

model TwinSimulationMatch {
  id           String         @id @default(cuid())
  simulationId String         @map("simulation_id")
  simulation   TwinSimulation @relation(fields: [simulationId], references: [id], onDelete: Cascade)

  homeTwinId String @map("home_twin_id")
  awayTwinId String @map("away_twin_id")
  homeScore  Int?
  awayScore  Int?
  round      Int    @default(1)

  // Each simulated match produces an attestation
  attestationId String? @map("attestation_id")

  playedAt  DateTime?
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("twin_simulation_matches")
}

// ============================================================================
// GROWTH: WAITLIST SIGNUPS
// ============================================================================

model WaitlistSignup {
  id        String   @id @default(cuid())
  email     String
  source    String?
  context   Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([email])
  @@map("waitlist_signups")
}

// ============================================================================
// EVENTS & NOTIFICATIONS
// ============================================================================

model ActivityEvent {
  id        String   @id @default(cuid())
  type      String   @map("type")
  squadId   String?  @map("squad_id")
  matchId   String?  @map("match_id")
  playerId  String?  @map("player_id")
  source    String   @default("app") @map("source")
  data      Json?    @map("data")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([squadId, createdAt])
  @@index([playerId, createdAt])
  @@index([type, createdAt])
  @@map("activity_events")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  type      String   @map("type")
  title     String   @map("title")
  message   String?  @map("message")
  data      Json?    @map("data")
  read      Boolean  @default(false) @map("read")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, read, createdAt])
  @@map("notifications")
}

// ============================================================================
// SEASONS — lifecycle container for competitive periods
// ============================================================================

model Season {
  id        String   @id @default(cuid())
  name      String
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  status    String   @default("active") // 'active' | 'completed'
  createdAt DateTime @default(now()) @map("created_at")

  @@index([status, endDate])
  @@map("seasons")
}

// ============================================================================
// TOURNAMENTS
// ============================================================================

model Tournament {
  id          String    @id @default(cuid())
  name        String
  type        String // 'squad' or 'individual'
  status      String    @default("open") // 'open', 'active', 'completed'
  maxEntries  Int       @default(8) @map("max_entries")
  createdBy   String?   @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  completedAt DateTime? @map("completed_at")

  entries TournamentEntry[]
  matches TournamentMatch[]

  @@index([status, createdAt])
  @@map("tournaments")
}

model TournamentEntry {
  id           String     @id @default(cuid())
  tournamentId String     @map("tournament_id")
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  userId       String?    @map("user_id")
  squadId      String?    @map("squad_id")
  seedNumber   Int        @map("seed_number") // Position in bracket (1-8)
  formation    String
  playStyle    String     @default("balanced") @map("play_style")
  color        String     @default("#3b82f6")
  playerNames  Json?      @map("player_names") // string[] for simulation
  enteredAt    DateTime   @default(now()) @map("entered_at")

  homeMatches TournamentMatch[] @relation("TournamentHomeEntry")
  awayMatches TournamentMatch[] @relation("TournamentAwayEntry")

  @@unique([tournamentId, seedNumber])
  @@index([tournamentId])
  @@map("tournament_entries")
}

model TournamentMatch {
  id           String          @id @default(cuid())
  tournamentId String          @map("tournament_id")
  tournament   Tournament      @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  round        String // 'quarter', 'semi', 'final'
  position     Int // Position within the round (1-4 for QF, 1-2 for SF, 1 for F)
  homeEntryId  String          @map("home_entry_id")
  homeEntry    TournamentEntry @relation("TournamentHomeEntry", fields: [homeEntryId], references: [id])
  awayEntryId  String          @map("away_entry_id")
  awayEntry    TournamentEntry @relation("TournamentAwayEntry", fields: [awayEntryId], references: [id])
  homeScore    Int?
  awayScore    Int?
  events       Json? // Goal events, possession, etc.
  status       String          @default("pending") // 'pending', 'in_progress', 'completed'
  playedAt     DateTime?       @map("played_at")

  @@unique([tournamentId, round, position])
  @@index([tournamentId, round])
  @@map("tournament_matches")
}
