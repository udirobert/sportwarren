{
  "name": "sportwarren-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "next dev",
    "build": "NODE_OPTIONS='--max-old-space-size=8192' next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "dev:server": "tsx watch server/index.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "dev:analytics": "python3 server/services/ai/player-analytics.py",
    "build:server": "tsc -p server/tsconfig.json",
    "deploy:contracts:local": "ALGORAND_NETWORK=local tsx scripts/deploy-contracts.ts",
    "deploy:contracts:testnet": "ALGORAND_NETWORK=testnet tsx scripts/deploy-contracts.ts",
    "deploy:contracts:mainnet": "ALGORAND_NETWORK=mainnet tsx scripts/deploy-contracts.ts",
    "verify:contracts": "tsx scripts/verify-contracts.ts",
    "test:contracts": "tsx scripts/test-contracts.ts",
    "test:chainlink": "tsx scripts/test-chainlink.ts",
    "test:kite": "tsx scripts/test-kite.ts",
    "kite:x402:preflight": "tsx scripts/kite-x402-preflight.ts",
    "kite:onchain-proof": "tsx scripts/kite-onchain-proof.ts",
    "test:verification": "tsx scripts/test-verification.ts",
    "prod:check": "tsx scripts/production-check.ts",
    "yellow:recover": "tsx scripts/yellow-recovery.ts",
    "setup:analytics": "bash scripts/setup-analytics.sh",
    "deploy:runtime:build": "bash scripts/build-runtime-artifact.sh",
    "deploy:runtime:release": "bash scripts/deploy-runtime-release.sh",
    "postinstall": "prisma generate",
    "test": "vitest run",
    "test:watch": "vitest",
    "assets:moments": "tsx scripts/render-before-after.tsx",
    "assets:social": "tsx scripts/render-social.tsx",
    "assets:stories": "tsx scripts/render-stories.tsx",
    "goat:demo": "tsx scripts/goat-agent-demo.ts",
    "goat:deploy:dry-run": "tsx scripts/deploy-to-goat.ts",
    "prepare": "husky"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "2": "3.0.0",
    "@aws-sdk/client-kms": "^3.1023.0",
    "@erc7824/nitrolite": "^0.5.3",
    "@kapso/whatsapp-cloud-api": "^0.2.1",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "@privy-io/react-auth": "^3.18.0",
    "@privy-io/wagmi": "^4.0.3",
    "@resvg/resvg-js": "2.6.2",
    "@rive-app/react-canvas": "4.28.6",
    "@sentry/nextjs": "^10.53.1",
    "@tanstack/react-query": "5.90.21",
    "@ton/core": "^0.63.1",
    "@tonconnect/ui-react": "^2.4.2",
    "@trpc/client": "^11.10.0",
    "@trpc/react-query": "^11.10.0",
    "@trpc/server": "^11.10.0",
    "algosdk": "^3.5.2",
    "axios": "1.13.6",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.3.1",
    "ethers": "^6.10.0",
    "form-data": "^4.0.0",
    "framer-motion": "^12.34.3",
    "html-to-image": "^1.11.13",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "kafkajs": "^2.2.4",
    "lucide-react": "^0.554.0",
    "next": "16.2.6",
    "node-telegram-bot-api": "^0.64.0",
    "openai": "^4.24.7",
    "pg": "^8.19.0",
    "posthog-js": "^1.368.0",
    "prisma": "^7.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "satori": "0.26.0",
    "satori-html": "0.3.2",
    "sharp": "0.34.5",
    "socket.io": "^4.7.4",
    "socket.io-client": "^4.7.4",
    "uuid": "^9.0.1",
    "viem": "^2.47.0",
    "wagmi": "^2.19.5",
    "ws": "^8.16.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@playwright/test": "^1.49.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.5",
    "@types/node-telegram-bot-api": "^0.64.7",
    "@types/pg": "^8.10.9",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.2",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "globals": "^15.9.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "madge": "^8.0.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.7.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "overrides": {
      "form-data@<2.5.4": ">=2.5.4"
    }
  },
  "optionalDependencies": {
    "@resvg/resvg-js-linux-x64-gnu": "2.6.2"
  }
}
