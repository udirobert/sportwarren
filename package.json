    "test:kite": "tsx scripts/test-kite.ts",
    "test:verification": "tsx scripts/test-verification.ts",
    "yellow:recover": "tsx scripts/yellow-recovery.ts",
    "setup:analytics": "bash scripts/setup-analytics.sh",
    "postinstall": "prisma generate",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
