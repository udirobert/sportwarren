##############################################################
# SportWarren — Environment Variables Reference
#
# Development: copy to .env.local
# Production: set these in your hosting provider dashboard
#
# Keys marked (REQUIRED) will cause the app to throw on startup
# if missing in production.
##############################################################

# ── Application ────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=SportWarren
NEXT_PUBLIC_CLIENT_URL=http://localhost:3000
# Socket.io server (optional real-time features)
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
TON_TREASURY_WALLET_ADDRESS=

# ── Monitoring (Sentry) ───────────────────────────────────
# Optional but recommended for production visibility
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Database (REQUIRED)
# The app THROWS in production if this is not set.
# Development: use Docker or a local Postgres instance
# Production: Neon, Supabase, Railway, or any managed Postgres
# url      → pooled connection string (pgbouncer) for the running app
# directUrl → non-pooled, used only for `prisma migrate deploy`
DATABASE_URL=postgresql://localhost:5432/sportwarren
LEGACY_DB_BOOTSTRAP=false
DATABASE_DIRECT_URL=postgresql://localhost:5432/sportwarren

# ── Algorand Blockchain ─────────────────────────────────────
ALGORAND_NETWORK=testnet
NEXT_PUBLIC_ALGORAND_NODE_URL=https://testnet-api.algonode.cloud
NEXT_PUBLIC_ALGORAND_INDEXER_URL=https://testnet-idx.algonode.cloud
# App ID of the deployed match verification smart contract on Algorand
ALGORAND_MATCH_VERIFICATION_APP_ID=756630713
# Deployer mnemonic — ONLY use testnet here, never expose mainnet key
DEPLOYER_MNEMONIC=
# Used as a dev fallback when no Pera/Defly wallet is installed
NEXT_PUBLIC_ALGORAND_TEST_MNEMONIC=

# ── Avalanche (Fuji Testnet) ────────────────────────────────
AVALANCHE_NETWORK=fuji
AVALANCHE_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
AVALANCHE_CHAIN_ID=43113
# Private key for server-side contract interactions (never expose to client)
AVALANCHE_PRIVATE_KEY=

# ── Privy Auth ──────────────────────────────────────────────
NEXT_PUBLIC_PRIVY_APP_ID=

# ── Kite AI (Agent Passports & Settlements) ─────────────────
KITE_API_URL=https://api.gokite.ai
KITE_API_KEY=
KITE_AGENT_WALLET=
NEXT_PUBLIC_KITE_ENABLED=true

# ── Yellow Payments (Treasury / Escrow / Match Fees) ────────
YELLOW_ENABLED=false
NEXT_PUBLIC_YELLOW_ENABLED=false
YELLOW_APP_ID=
YELLOW_API_KEY=
NEXT_PUBLIC_YELLOW_APP_ID=
YELLOW_CLEARNODE_URL=wss://clearnet-sandbox.yellow.com/ws
NEXT_PUBLIC_YELLOW_CLEARNODE_URL=wss://clearnet-sandbox.yellow.com/ws
YELLOW_ASSET_SYMBOL=USDC
NEXT_PUBLIC_YELLOW_ASSET_SYMBOL=USDC
NEXT_PUBLIC_YELLOW_PLATFORM_WALLET=
YELLOW_MATCH_FEE_AMOUNT=1
NEXT_PUBLIC_YELLOW_MATCH_FEE_AMOUNT=1
NEXT_PUBLIC_YELLOW_SCOPE=sportwarren
NEXT_PUBLIC_YELLOW_EIP712_DOMAIN_NAME=Yellow Network
NEXT_PUBLIC_YELLOW_ALLOWANCE_AMOUNT=1000000000

# ── Phygital Oracles (CRE) ─────────────────────────────────
NEXT_PUBLIC_CHAINLINK_ENABLED=true

# WEATHER: Open-Meteo (Sovereign Default) — No Key Required
# Fallback: OpenWeatherMap (requires key)
OPENWEATHER_API_KEY=

# LOCATION: OpenStreetMap (Sovereign Default) — No Key Required
# Fallback: LocationIQ or Google Maps (requires key)
GEO_VERIFICATION_API_KEY=

# ── WalletConnect (REQUIRED for wallet modal) ───────────────
# Get your project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ── Inference (REQUIRED for Agentic Narrative) ───────────
# Venice AI — used for "Parallel Season" Captain Reports
# Get your API key at https://venice.ai
VENICE_API_KEY=
VENICE_MODEL_ID="llama-3.1-70b-instruct" # Default model

# OpenAI (Fallback/Transcription only)
OPENAI_API_KEY=

# ── JWT (legacy standalone server only) ─────────────────────
# Not required for the current Next.js wallet-auth path.
# Only set this if you still run `server/index.ts`.
JWT_SECRET=change-this-to-a-random-secret-in-production

# ── AWS S3 (match photo uploads, optional) ──────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=sportwarren-media

# ── Lens Protocol ───────────────────────────────────────────
# Lens Chain Sepolia testnet — used for social graph + highlight sharing
# No env vars needed beyond the chain config in WalletContext

# ── Communication Bridge (server/index.ts only) ─────────────
# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# WhatsApp (via whatsapp-web.js + Puppeteer — requires Chrome locally)
# No extra env vars needed; scans QR on first run

# XMTP V3 Messaging
# Private key for the server-side XMTP bot wallet (hex, 0x-prefixed)
# Generate with: node -e "const w = require('ethers').Wallet.createRandom(); console.log(w.privateKey)"
XMTP_PRIVATE_KEY=
# 32-byte hex encryption key for the local XMTP SQLite DB
# Generate with: node -e "console.log('0x' + require('crypto').randomBytes(32).toString('hex'))"
XMTP_DB_ENCRYPTION_KEY=
# Server XMTP environment: 'dev' or 'production'
XMTP_ENV=dev
# Browser XMTP environment (must match XMTP_ENV)
NEXT_PUBLIC_XMTP_ENV=dev

##############################################################
# WALLET AUTH FLOW (how signing works post-blocker fix)
#
# 1. User clicks Connect in WalletConnectModal
# 2. WalletContext.connect() detects browser wallet (Pera/MetaMask)
# 3. Client fetches a challenge: GET /api/auth/challenge
# 4. User signs the challenge locally in their wallet
# 5. Signature stored in localStorage (sw_auth_signature etc.)
# 6. TRPCProvider reads these on every request as x-wallet-* headers
# 7. Server verifies the signature in createTRPCContext
# 8. protectedProcedure gates any mutation that needs auth
##############################################################

##############################################################
# DEPLOYMENT CHECKLIST
# [ ] DATABASE_URL set in hosting provider → run prisma migrate deploy
# [ ] NEXT_PUBLIC_YELLOW_PLATFORM_WALLET set if using live Yellow match fee payouts
# [ ] NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID set
# [ ] NEXT_PUBLIC_ALGORAND_NODE_URL / INDEXER_URL set
# [ ] JWT_SECRET is set only if the legacy standalone server is deployed
# [ ] XMTP_PRIVATE_KEY + XMTP_DB_ENCRYPTION_KEY set for server messaging
# [ ] Hit /api/health on the live domain — all checks must be 'ok'
# [ ] Test wallet connect from the live domain (not localhost)
##############################################################
##############################################################
# 🏛 ARCHITECTURE: CRE vs EXTERNAL BACKEND
#
# SportWarren uses a "Hybrid Sovereign" architecture:
# 
# 1. Chainlink CRE (Orchestration): 
#    - Orchestrates Weather (OpenWeather) & Location (Google Maps)
#    - Fetches Agentic Inference (Venice AI)
#    - Generates the "Truth Proof" (verificationDetails)
#
# 2. Vercel/Hetzner (Web App):
#    - Hosts the Next.js Frontend & tRPC API
#    - Manages the Persistent State (Neon PostgreSQL)
#    - Displays the CRE "Truth" to the end-user
#
# 3. Blockchain (Settlement):
#    - Algorand: Handles the immutable match record hashes
#    - Lens Chain: Handles social graph and phygital highlights
##############################################################
