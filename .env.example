# No env vars needed beyond the chain config in WalletContext

# ── Communication Bridge (server/index.ts only) ─────────────
# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

##############################################################
# WALLET AUTH FLOW (how signing works post-blocker fix)
#
# 1. User clicks Connect in WalletConnectModal
# 2. WalletContext.connect() detects browser wallet (Pera/MetaMask)
# 3. Client fetches a challenge: GET /api/auth/challenge
# 4. User signs the challenge locally in their wallet
# 5. Signature stored in localStorage (sw_auth_signature etc.)
# 6. TRPCProvider reads these on every request as x-wallet-* headers
# 7. Server verifies the signature in createTRPCContext
# 8. protectedProcedure gates any mutation that needs auth
##############################################################

##############################################################
# DEPLOYMENT CHECKLIST
# [ ] DATABASE_URL set in hosting provider → run prisma migrate deploy
# [ ] NEXT_PUBLIC_YELLOW_PLATFORM_WALLET set if using live Yellow match fee payouts
# [ ] NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID set
# [ ] NEXT_PUBLIC_ALGORAND_NODE_URL / INDEXER_URL set
# [ ] JWT_SECRET is set only if the legacy standalone server is deployed
# [ ] Hit /api/health on the live domain — all checks must be 'ok'
# [ ] Test wallet connect from the live domain (not localhost)
##############################################################
# ── Social / Media (encrypted squad media & sharing) ─────────
# Required: 32-byte base64 master key for media encryption
MEDIA_MASTER_KEY=                    # Local dev only: raw 32-byte base64 key (openssl rand -base64 32)
# Production: use KMS instead of MEDIA_MASTER_KEY
KMS_KEY_ID=                          # AWS KMS key ARN or alias (e.g. arn:aws:kms:us-east-1:123:key/abc)
MEDIA_KEY_CIPHERTEXT=                # Base64 KMS ciphertext of your 32-byte media key
AWS_REGION=us-east-1                 # Region where your KMS key lives
AWS_ACCESS_KEY_ID=                   # IAM credentials with kms:Decrypt on the key above
AWS_SECRET_ACCESS_KEY=

# Optional storage backend
# MEDIA_STORAGE=local | ipfs
MEDIA_STORAGE=local
IPFS_GATEWAY_UPLOAD_URL=
IPFS_GATEWAY_READ_URL=
IPFS_GATEWAY_API_KEY=

# Optional: short-lived signed URL HMAC secret (>=32 bytes base64)
MEDIA_SHARE_SECRET=

# Optional: admin token to authorize storage GC endpoint
ADMIN_TOKEN=

# Optional: per-squad media quota (MB). 0 to disable.
MEDIA_SQUAD_QUOTA_MB=0

# Public base URL used to construct share links and rate links
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Client URL — used by WhatsApp/Telegram agents to build links back to the web app
# Production: https://www.sportwarren.com
CLIENT_URL=http://localhost:3000
NEXT_PUBLIC_CLIENT_URL=http://localhost:3000

# ── Rate Token (WhatsApp → Web auth) ────────────────────────
# Secret for signing JWT rate tokens. Falls back to CRON_SECRET or MEDIA_SHARE_SECRET.
# Set a dedicated secret in production (openssl rand -base64 32).
RATE_TOKEN_SECRET=

# ── Cron Secret ─────────────────────────────────────────────
# Protects /api/cron/* endpoints. Set in production and match the crontab Authorization header.
CRON_SECRET=

# ── Lens (public social) ──────────────────────────────────────
ENABLE_LENS_SOCIAL=false
NEXT_PUBLIC_LENS_SOCIAL_ENABLED=false
LENS_GATEWAY_URL=
LENS_API_BASE=
LENS_API_KEY=

# ── Background Workers (server) ───────────────────────────────
# Enable automatic cleanup of soft-deleted media on the backend
ENABLE_MEDIA_GC_WORKER=false
# How often to run (minutes) and how old a deletion must be (hours)
MEDIA_GC_INTERVAL_MIN=60
MEDIA_GC_OLDER_HOURS=24

# ── WhatsApp via Kapso (Kite AI Hackathon) ────────────────────
# https://app.kapso.ai — get an API key + onboard a Meta number with `kapso setup`
KAPSO_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
KAPSO_API_BASE_URL=https://app.kapso.ai/api/meta/

# ── Kite chain / x402 (Kite AI Hackathon) ─────────────────────
# Treasury wallet used for direct non-x402 payouts only.
WEB3_PRIVATE_KEY=
KITE_RPC_URL=https://rpc-testnet.gokite.ai
KITE_CHAIN_ID=2368
KITE_FACILITATOR_URL=https://facilitator.pieverse.io
KITE_USDC_ADDRESS=0x0fF5393387ad2f9f691FD6Fd28e07E3969e27e63
KITE_USDC_DECIMALS=18
KITE_X402_VERSION=2
# Set true only for local demos; production must use the Pieverse facilitator.
KITE_X402_SIMULATE=false
KITE_X402_SCHEME=exact
KITE_X402_NETWORK=eip155:2368
# Passport judge demo (`kite-proof`): discovery-listed merchant (Weather on Base ~$0.01 USDC/request).
KITE_DEMO_SERVICE_URL=https://weather.hugen.tokyo/weather/current?city=London
KITE_DEMO_MAX_USDC=0.02
KITE_X402_PAY_TO_ADDRESS=
KITE_X402_TOKEN_TYPE=USDC
KPASS_BIN=kpass
# Override HOME for kpass config lookup (default: process HOME)
# KPASS_HOME=/home/deploy
KITE_EXPLORER_URL=https://testnet.kitescan.ai
# Internal scout report (WhatsApp + auto-scout cron) uses the in-process
# createScoutReport service and records a SportWarren receipt.
KITE_SCOUT_PRICE_USDC=0.005
KITE_SCOUT_MAX_USDC=0.50
KITE_SCOUT_MAX_USDC_SQUAD=2.50
# Optional dev/testing overrides. Set KITE_SCOUT_DEV_USER_IDS to comma-separated User.id values.
KITE_SCOUT_DEV_USER_IDS=
KITE_SCOUT_DEV_MAX_USDC=10
KITE_SCOUT_USER_LIMIT_OVERRIDES_USDC=
KITE_SCOUT_SQUAD_LIMIT_OVERRIDES_USDC=
KITE_SCOUT_UNLIMITED_USER_IDS=
KITE_SCOUT_UNLIMITED_SQUAD_IDS=

# ── TinyFish Web Agent (real web data for scouting) ────────────────
# Get an API key at https://agent.tinyfish.ai/api-keys
# Search + Fetch are free. Agent API uses credits.
TINYFISH_API_KEY=

# ── GOAT Network (Bitcoin-secured L2, ERC-8004 agent identity, x402) ──
# https://docs.goat.network — Bitcoin-secured infrastructure for agent commerce.
# Chain IDs: 2345 (mainnet), 48816 (testnet3). Default: testnet3.
GOAT_CHAIN_ID=48816
GOAT_RPC_URL=https://rpc.testnet3.goat.network
# Private key for GOAT Network agent registration and x402 settlement.
# Falls back to WEB3_PRIVATE_KEY if not set.
GOAT_PRIVATE_KEY=
# ERC-8004 canonical contract addresses (testnet3 defaults; override for mainnet).
GOAT_IDENTITY_REGISTRY_ADDRESS=0x556089008Fc0a60cD09390Eca93477ca254A5522
GOAT_REPUTATION_REGISTRY_ADDRESS=0xd9140951d8aE6E5F625a02F5908535e16e3af964
# x402 payment settings for GOAT Network.
GOAT_FACILITATOR_URL=
GOAT_USDC_ADDRESS=
GOAT_USDC_DECIMALS=18
GOAT_X402_SCHEME=exact
# Set to 2345 for mainnet GOAT x402 payments.
GOAT_X402_NETWORK=eip155:48816

# ── Agent Autonomy Policy ─────────────────────────────────────────
# Controls what agents can do without human approval:
#   observe    — read-only: search, budget, status. No spending.
#   integrate  — can scout (with optional confirmation). No hire/pay.
#   automate   — full spending within budget limits (default).
AUTONOMY_LEVEL=automate

# When true, agents ask "Reply yes to confirm" before any spending
# action (scout, hire, pay). Can be overridden per-squad via WhatsApp.
KITE_REQUIRE_CONFIRMATION=false

# Judge/hackathon demo gate: enables the WhatsApp `kite-proof` command and
# the live x402 merchant probe. Leave unset in production. The companion
# script `pnpm exec tsx scripts/kite-onchain-proof.ts` is always available.
KITE_DEMO_MODE=
